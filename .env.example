# Preet English - Environment Variables Example
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL="file:./preet_english.db"

# Application Environment
NODE_ENV="development"

# Optional: API Keys (if you add external services later)
# OPENAI_API_KEY="your-openai-key-here"
# GOOGLE_TRANSLATE_API_KEY="your-google-translate-key"

# Optional: Analytics (if you add tracking later)
# GOOGLE_ANALYTICS_ID="your-ga-id"
# MIXPANEL_TOKEN="your-mixpanel-token"

# Optional: Authentication (if you add user accounts later)
# JWT_SECRET="your-jwt-secret"
# SESSION_SECRET="your-session-secret"

# Optional: Email Service (for notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"

# Optional: Cloud Storage (for user uploads)
# AWS_ACCESS_KEY_ID="your-aws-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret"
# AWS_BUCKET_NAME="your-bucket-name"

# Optional: CDN Configuration
# CDN_URL="https://your-cdn-domain.com"

# Development Settings
PORT="5000"
HOST="localhost"